{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "residence-risk-api",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-17",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "rrw-db",
			"database_id": "8f35001a-59ba-45f2-9c8e-462f4b2360ac"
		}
	]
}
